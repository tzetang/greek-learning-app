# AI tutor — OpenAI-compatible endpoint. Copy to .env.local and fill in.
# .env.local is gitignored; never commit real keys.
#
# Example below uses OpenRouter. The code appends /v1/chat/completions to the
# base URL, so omit the /v1 here.
TUTOR_BASE_URL=https://openrouter.ai/api
TUTOR_MODEL=deepseek/deepseek-v4-flash
TUTOR_API_KEY=your-openrouter-key
