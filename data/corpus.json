  "glossary": [
    {
      "term": "Transliteration",
      "definition": "Writing the English alphabet equivalent of Greek letters",
      "category": "writing",
      "source": "Glossary Week 1.pdf"
    },
    {
      "term": "Diphthong",
      "definition": "Two vowels producing one sound; the second vowel is always ι or υ",
      "category": "writing",
      "source": "Glossary Week 1.pdf"
    },
    {
      "term": "Rough breathing mark",
      "definition": "The mark (῾) placed over an initial vowel or ρ, adding an 'h' sound",
      "category": "writing",
      "source": "Glossary Week 1.pdf"
    },
    {
      "term": "Smooth breathing mark",
      "definition": "The mark (᾿) placed over an initial vowel indicating no 'h' sound; silent",
      "category": "writing",
      "source": "Glossary Week 1.pdf"
    },
    {
      "term": "Accent",
      "definition": "A mark indicating pitch or stress: acute (´), grave (`), or circumflex (͂). Not assessed in this course.",
      "category": "writing",
      "source": "Glossary Week 1.pdf"
    },
    {
      "term": "Iota subscript",
      "definition": "A small ι written under α, η, or ω (ᾳ, ῃ, ῳ); represents a formerly pronounced vowel",
      "category": "writing",
      "source": "Glossary Week 1.pdf"
    },
    {
      "term": "Gamma nasal",
      "definition": "When γ appears before γ, κ, χ, or ξ it is pronounced like 'n' (e.g. ἄγγελος = 'angelos')",
      "category": "writing",
      "source": "Glossary Week 1.pdf"
    },
    {
      "term": "Noun",
      "definition": "A word that stands for someone or something",
      "category": "grammar",
      "source": "Glossary Week 2.pdf"
    },
    {
      "term": "Adjective",
      "definition": "A word that modifies a noun",
      "category": "grammar",
      "source": "Glossary Week 2.pdf"
    },
    {
      "term": "Definite article",
      "definition": "The Greek equivalent of English 'the'; it agrees with the noun in gender, case, and number",
      "category": "grammar",
      "source": "Glossary Week 2.pdf"
    },
    {
      "term": "Inflection",
      "definition": "When a noun changes its form to show its role: subject, object, indirect object, or possessive",
      "category": "grammar",
      "source": "Glossary Week 2.pdf"
    },
    {
      "term": "Declension",
      "definition": "A pattern of noun endings. There are three: 1st (feminine α/η), 2nd (masculine ο), 3rd (neuter/consonant stems). This course covers 2nd declension masculine only.",
      "category": "grammar",
      "source": "Glossary Week 2.pdf"
    },
    {
      "term": "Nominative case",
      "definition": "The subject of the sentence or verb",
      "category": "cases",
      "source": "Glossary Week 2.pdf"
    },
    {
      "term": "Accusative case",
      "definition": "The direct object of the verb",
      "category": "cases",
      "source": "Glossary Week 2.pdf"
    },
    {
      "term": "Dative case",
      "definition": "The indirect object; translated with 'to', 'in', 'with', or 'for'",
      "category": "cases",
      "source": "Glossary Week 2.pdf"
    },
    {
      "term": "Genitive case",
      "definition": "The possessive case; translated with 'of' or apostrophe-s",
      "category": "cases",
      "source": "Glossary Week 2.pdf"
    },
    {
      "term": "Parse (a verb)",
      "definition": "To provide the person, number, and tense of a verb (plus mood for exams)",
      "category": "grammar",
      "source": "Glossary Week 2.pdf"
    },
    {
      "term": "Decline (a noun)",
      "definition": "To modify a noun's ending to show its role (subject, object, etc.)",
      "category": "grammar",
      "source": "Glossary Week 2.pdf"
    },
    {
      "term": "Conjugate (a verb)",
      "definition": "To modify a verb for person, number, tense, voice, and mood",
      "category": "grammar",
      "source": "Glossary Week 2.pdf"
    },
    {
      "term": "Active voice",
      "definition": "The subject produces the action",
      "category": "voice",
      "source": "IBG 2026 6.pdf"
    },
    {
      "term": "Passive voice",
      "definition": "The subject receives the action",
      "category": "voice",
      "source": "IBG 2026 6.pdf"
    },
    {
      "term": "Middle voice",
      "definition": "The subject produces the action but is also affected by it",
      "category": "voice",
      "source": "IBG 2026 6.pdf"
    },
    {
      "term": "Present tense",
      "definition": "Action occurring in the present",
      "category": "tenses",
      "source": "IBG 2026 6.pdf"
    },
    {
      "term": "Future tense",
      "definition": "Action that will occur in the future",
      "category": "tenses",
      "source": "IBG 2026 6.pdf"
    },
    {
      "term": "Aorist tense",
      "definition": "A simple past tense in the indicative mood",
      "category": "tenses",
      "source": "IBG 2026 6.pdf"
    },
    {
      "term": "Perfect tense",
      "definition": "Action brought to completion whose effects are felt in the present",
      "category": "tenses",
      "source": "IBG 2026 6.pdf"
    },
    {
      "term": "Imperfect tense",
      "definition": "Imperfective action normally occurring in past time",
      "category": "tenses",
      "source": "IBG 2026 6.pdf"
    },
    {
      "term": "Indicative mood",
      "definition": "Describes what is; states facts",
      "category": "moods",
      "source": "IBG 2026 6.pdf"
    },
    {
      "term": "Subjunctive mood",
      "definition": "Expresses possibility or probability; used after ἵνα ('in order that')",
      "category": "moods",
      "source": "IBG 2026 6.pdf"
    },
    {
      "term": "Optative mood",
      "definition": "Expresses a wish or prayer; two steps removed from reality (e.g. μὴ γένοιτο = 'may it never be')",
      "category": "moods",
      "source": "Optative Examples.pdf"
    },
    {
      "term": "Imperative mood",
      "definition": "A command or urgent request",
      "category": "moods",
      "source": "IBG 2026 6.pdf"
    },
    {
      "term": "Infinitive",
      "definition": "A non-finite verbal noun; it has tense and voice but no person or number",
      "category": "moods",
      "source": "IBG 2026 6.pdf"
    },
    {
      "term": "Participle",
      "definition": "A non-finite verbal adjective; it has tense, voice, number, case, and person",
      "category": "moods",
      "source": "IBG 2026 6.pdf"
    }
  ],
